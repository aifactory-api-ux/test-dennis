# ============================================
# test Dennis - Environment Variables Template
# ============================================
# Copiar este archivo a .env y configurar los valores

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=testdennis

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Configuration
# ============================================
# IMPORTANTE: Cambiar en producción
JWT_SECRET=test-dennis-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ============================================
# Service Ports
# ============================================
AUTH_SERVICE_PORT=8001
OPPORTUNITY_SERVICE_PORT=8002
INTERACTION_SERVICE_PORT=8003
FRONTEND_PORT=3000

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:8001

# ============================================
# Application Settings
# ============================================
# Tiempo de espera para healthchecks (segundos)
HEALTHCHECK_TIMEOUT=5
# Número máximo de reintentos para healthchecks
HEALTHCHECK_RETRIES=5
