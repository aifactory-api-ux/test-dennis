# ============================================
# test Dennis - Git Ignore Rules
# ============================================

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs
*.log
npm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Backend specific
*.tsbuildinfo

# Frontend specific
*.tsbuildinfo
vite.config.ts.timestamp*
vite.config.ts.timestamp

# Database
*.sql
*.dump

# Docker
.dockerignore should be in root

# Python (if any scripts)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
venv/
.venv/

# Misc
*.cache
*.pid
*.seed
*.pid.lock
